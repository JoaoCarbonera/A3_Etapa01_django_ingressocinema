@startuml SistemaIngressosCinema

class Usuario {
  + id
  + nome
  + email
  + cpf
  + data_nascimento
}

class Filme {
  + id
  + titulo
  + data_lancamento
  + descricao
  + duracao
  + classificacao_indicativa
}

class Cinema {
  + id
  + nome
  + endereco
  + cidade
  + telefone
}

class Sala {
  + id
  + numero
  + capacidade
  + tipo_tela
  + tipo_sonorizacao
}

class Cadeira {
  + id
  + codigo
  + fileira
  + numero
  + tipo
  + acessivel
}

class Sessao {
  + id
  + horario
  + preco
  + tipo_exibicao
  + idioma
  + legendado
}

class Ingresso {
  + id
  + codigo
  + data_emissao
  + utilizado
  + valor_pago
  + tipo_ingresso
}

class Compra {
  + id
  + data
  + valor_total
  + forma_pagamento
  + status
  + codigo_confirmacao
}

' Relacionamentos
Usuario "1" --> "n" Compra
Filme "1" --> "n" Sessao
Cinema "1" --> "n" Sala
Sala "1" --> "n" Cadeira
Sala "1" --> "n" Sessao
Sessao "1" --> "n" Ingresso
Compra "1" --> "n" Ingresso
Ingresso "1" --> "1" Cadeira
Cinema "1" --> "n" Sessao

@enduml